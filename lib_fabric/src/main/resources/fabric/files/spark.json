{
  "spark.submit.deployMode": "client",
  "spark.driver.host": "${driverHost}",
  "spark.driver.port": "${driverPort}",
  "spark.blockManager.port": "${blockManagerPort}",
  "spark.driver.bindAddress": "0.0.0.0",
  "spark.driver.memory": "${driverMemory}",
  "spark.executor.memory": "${executorMemory}",
  "spark.executor.cores": "${executorCores}",
  "spark.kubernetes.executor.limit.cores": "${executorLimitCores}",
  "spark.kubernetes.namespace": "${namespace}",
  "spark.kubernetes.container.image": "${containerImage}",
  "spark.kubernetes.container.image.pullSecrets": "${imagePullSecret}",
  "spark.kubernetes.container.image.pullPolicy": "IfNotPresent",
  "spark.kubernetes.authenticate.driver.serviceAccountName": "${serviceAccountName}",
  "spark.kubernetes.authenticate.executor.serviceAccountName": "${serviceAccountName}",
  "spark.kubernetes.executor.podNamePrefix": "${podNamePrefix}",
  "spark.kubernetes.executor.podTemplateFile": "${podTemplateMount}",
  "spark.scheduler.mode": "FAIR",
  "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
  "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
  "spark.sql.files.maxPartitionBytes": "267108864",
  "spark.databricks.delta.optimize.maxFileSize": "267108864",
  "spark.sql.adaptive.advisoryPartitionSizeInBytes": "267108864",
  "spark.sql.adaptive.enabled": "true",
  "spark.sql.adaptive.skewJoin.enabled": "true",
  "spark.sql.adaptive.coalescePartitions.enabled": "true",
  "spark.sql.adaptive.localShuffleReader.enabled": "true",
  "spark.sql.execution.arrow.pyspark.enabled": "true",
  "spark.default.parallelism": "254",
  "spark.sql.shuffle.partitions": "254",
  "spark.dynamicAllocation.enabled": "true",
  "spark.dynamicAllocation.shuffleTracking.enabled": "true",
  "spark.dynamicAllocation.minExecutors": "${minExecutors}",
  "spark.dynamicAllocation.maxExecutors": "${maxExecutors}",
  "spark.dynamicAllocation.executorIdleTimeout": "60s",
  "spark.hadoop.dfs.client.read.shortcircuit": "true",
  "spark.hadoop.dfs.domain.socket.path": "${dnSocketPath}/dn.sock",
  "spark.hadoop.dfs.replication": "1",
  "spark.sql.parquet.compression.codec": "gzip",
  "spark.databricks.delta.autoOptimize.optimizeWrite": "true",
  "spark.databricks.delta.autoOptimize.autoCompact": "true",
  "spark.driver.maxResultSize": "6g"
}
